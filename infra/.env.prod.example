# Kandidly production environment. Copy to infra/.env.prod ON THE SERVER ONLY:
#   cp infra/.env.prod.example infra/.env.prod && chmod 600 infra/.env.prod
# Never commit .env.prod. Every service receives this whole file via env_file
# (compose.prod.yml); deploy.sh also sources it for build args and the health
# check. Values may not reference each other (${...} is NOT expanded here) —
# write full literal values, e.g. the domain appears in several URLs below.
#
# Generate secrets:
#   openssl rand -hex 32                              # tokens / secrets

# ── domain & edge (Caddy) ─────────────────────────────────────────────────────
# The SPA is served at DOMAIN itself; backend at api.DOMAIN; MinIO at
# files.DOMAIN. A records for all three → the instance's elastic IP.
DOMAIN=kandidly.vishalkhare.com
ACME_EMAIL=you@example.com

# Baked into the SPA bundle at build time (web/Dockerfile.prod).
VITE_API_BASE=https://api.kandidly.vishalkhare.com

# ── Postgres (server creds; also embedded in KANDIDLY_DATABASE_URL below) ────
POSTGRES_USER=kandidly
POSTGRES_PASSWORD=
POSTGRES_DB=kandidly

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=kandidly
MINIO_ROOT_PASSWORD=
# Public origin MinIO believes it is served from (the Caddy files subdomain);
# must match KANDIDLY_S3_PUBLIC_ENDPOINT or presigned signatures break.
MINIO_SERVER_URL=https://files.kandidly.vishalkhare.com
# No web console in prod.
MINIO_BROWSER=off

# ── app core ──────────────────────────────────────────────────────────────────
KANDIDLY_ENV=prod
# Must embed POSTGRES_USER/PASSWORD/DB from above (no ${} expansion here).
KANDIDLY_DATABASE_URL=postgresql+asyncpg://kandidly:CHANGE-ME@postgres:5432/kandidly
KANDIDLY_REDIS_URL=redis://redis:6379/0

# ── object store ──────────────────────────────────────────────────────────────
# In-cluster endpoint for the backend/worker; public endpoint is what gets
# signed into presigned URLs handed to the browser (Caddy → minio:9000).
KANDIDLY_S3_ENDPOINT=http://minio:9000
KANDIDLY_S3_PUBLIC_ENDPOINT=https://files.kandidly.vishalkhare.com
# KANDIDLY_S3_ACCESS_KEY / KANDIDLY_S3_SECRET_KEY are NOT set here on
# purpose: compose.prod.yml derives them from MINIO_ROOT_USER/PASSWORD so the
# app and MinIO can never disagree (hand-copied values drifted once and
# 500'd every upload). Any values still present in .env.prod are overridden.
KANDIDLY_S3_REGION=us-east-1

# ── auth (WorkOS AuthKit → app-minted HS256 JWT) ─────────────────────────────
# Dev tokens are dead in prod: verify_jwt rejects them whenever KANDIDLY_ENV
# != dev, and AUTH_DEV_MODE=false also hides /api/public/dev-users. Keep both.
KANDIDLY_AUTH_DEV_MODE=false
# Signs the app's own bearer JWTs (openssl rand -hex 32). Rotating it logs
# every session out.
KANDIDLY_JWT_SECRET=
# WorkOS dashboard (production environment) → API Keys. The redirect URI must
# also be allowlisted under Redirects in the dashboard.
KANDIDLY_WORKOS_API_KEY=
KANDIDLY_WORKOS_CLIENT_ID=
KANDIDLY_WORKOS_REDIRECT_URI=https://api.kandidly.vishalkhare.com/api/auth/callback

# Internal service auth (agent/worker → backend). Random 64-hex, e.g.
# `openssl rand -hex 32`. MUST be non-empty — an empty value is worse than an
# absent line: both sides fall back to the same dev default when unset, but an
# empty value makes the backend 401 every agent /internal call (2026-07-17).
# deploy.sh refuses to run with it empty; ops.yml rotate-service-token sets a
# fresh one on the box without the secret leaving it.
KANDIDLY_SERVICE_TOKEN=

# ── bootstrap accounts (read by `python -m app.db.seed_prod`, one-time) ──────
KANDIDLY_BOOTSTRAP_ADMIN_EMAIL=you@example.com
# Optional shared test-candidate account; needed to run an interview until
# real candidate auth exists (the /i/<token> picker lists candidate accounts).
KANDIDLY_BOOTSTRAP_CANDIDATE_EMAIL=candidate@example.com

# ── transactional email (Resend — org/candidate invites) ────────────────────
# API key from resend.com → API Keys. Sending from this domain requires the
# domain to be verified in Resend (DKIM/SPF DNS records — docs/deploy-ec2.md
# §11). Empty key → transport falls back to console (emails only logged).
KANDIDLY_RESEND_API_KEY=
KANDIDLY_EMAIL_FROM=Kandidly <no-reply@kandidly.vishalkhare.com>

# ── captcha (reCAPTCHA v3, prod keys — guards candidate form submit) ─────────
KANDIDLY_RECAPTCHA_SITE_KEY=
KANDIDLY_RECAPTCHA_SECRET_KEY=
KANDIDLY_RECAPTCHA_MIN_SCORE=0.5

# ── LiveKit Cloud (prod project: rooms + inference for STT/LLM/TTS) ──────────
KANDIDLY_LIVEKIT_URL=wss://your-prod-project.livekit.cloud
KANDIDLY_LIVEKIT_API_KEY=
KANDIDLY_LIVEKIT_API_SECRET=
# LiveKit-inference model ids (agent/worker.py defaults shown; the model must
# be enabled on the LiveKit project or the agent joins but never speaks).
KANDIDLY_INFERENCE_STT=assemblyai/universal-streaming
KANDIDLY_INFERENCE_LLM=google/gemini-2.5-flash
KANDIDLY_INFERENCE_TTS=cartesia/sonic-2
KANDIDLY_INFERENCE_TTS_VOICE=

# ── non-realtime LLM roles (OpenRouter; required for resume extract, plan,
#    scoring, vision proctoring, integrity — without it those jobs stall) ─────
KANDIDLY_OPENROUTER_API_KEY=
KANDIDLY_VISION_LLM=openrouter:qwen/qwen2.5-vl-72b-instruct

# Optional: lifts GitHub scraping rate limit (60→5000/hr) for enrichment.
KANDIDLY_GITHUB_TOKEN=

# ── web/interview tuning ──────────────────────────────────────────────────────
# Browser-facing web origin — also the backend's CORS allowlist entry.
KANDIDLY_BASE_URL_WEB=https://kandidly.vishalkhare.com
KANDIDLY_MAX_INTERVIEW_SECONDS=1800
KANDIDLY_WRAP_TRIGGER_SECONDS=180
KANDIDLY_SNAPSHOT_INTERVAL_S=10
KANDIDLY_AGENT_MAX_CONCURRENT=50
