# Kandidly environment (SPEC §6.1). Copy to infra/.env and fill secrets.
# All app-consumed vars are prefixed KANDIDLY_ in code via pydantic-settings.

# --- core ---
KANDIDLY_ENV=dev

# --- datastores (compose DNS names; override for managed prod) ---
KANDIDLY_DATABASE_URL=postgresql+asyncpg://kandidly:kandidly@postgres:5432/kandidly
KANDIDLY_REDIS_URL=redis://redis:6379/0

# --- object store (MinIO in dev) ---
KANDIDLY_S3_ENDPOINT=http://minio:9000
KANDIDLY_S3_ACCESS_KEY=kandidly
KANDIDLY_S3_SECRET_KEY=kandidly-secret
KANDIDLY_S3_REGION=us-east-1

# --- auth contract (SPEC §3.6) ---
KANDIDLY_JWT_PUBLIC_KEY=
KANDIDLY_JWT_ALG=RS256
KANDIDLY_AUTH_DEV_MODE=true

# --- internal service auth (agent/worker <-> backend, SPEC §12.4) ---
KANDIDLY_SERVICE_TOKEN=dev-service-token-change-me

# --- LiveKit ---
KANDIDLY_LIVEKIT_URL=
KANDIDLY_LIVEKIT_API_KEY=
KANDIDLY_LIVEKIT_API_SECRET=

# --- providers ---
KANDIDLY_DEEPGRAM_API_KEY=
KANDIDLY_CARTESIA_API_KEY=
KANDIDLY_ANTHROPIC_API_KEY=
KANDIDLY_OPENAI_API_KEY=
KANDIDLY_GOOGLE_API_KEY=

# --- model matrix (SPEC §3.3) ---
KANDIDLY_REALTIME_LLM=anthropic:claude-haiku-4-5
KANDIDLY_EXTRACT_LLM=anthropic:claude-sonnet-4-6
KANDIDLY_PLAN_LLM=anthropic:claude-sonnet-4-6
KANDIDLY_ANNOTATE_LLM=anthropic:claude-haiku-4-5
KANDIDLY_SCORE_LLM=anthropic:claude-sonnet-4-6
KANDIDLY_REPORT_LLM=anthropic:claude-sonnet-4-6
KANDIDLY_STT=deepgram:nova-3
KANDIDLY_TTS=cartesia:sonic
KANDIDLY_TTS_VOICE=

# --- interview tuning ---
KANDIDLY_BASE_URL_WEB=http://localhost:5173
KANDIDLY_MAX_INTERVIEW_SECONDS=1800
KANDIDLY_WRAP_TRIGGER_SECONDS=180
KANDIDLY_REJOIN_GRACE_SECONDS=600
KANDIDLY_SNAPSHOT_MIN_S=5
KANDIDLY_SNAPSHOT_MAX_S=10
KANDIDLY_SCORING_RUNS=3
KANDIDLY_AGENT_MAX_CONCURRENT=50
KANDIDLY_RETENTION_DAYS_SNAPSHOTS=180
KANDIDLY_RETENTION_DAYS_AUDIO=365

# --- MinIO server creds (compose only, not app-facing) ---
MINIO_ROOT_USER=kandidly
MINIO_ROOT_PASSWORD=kandidly-secret

# --- Postgres server creds (compose only) ---
POSTGRES_USER=kandidly
POSTGRES_PASSWORD=kandidly
POSTGRES_DB=kandidly
