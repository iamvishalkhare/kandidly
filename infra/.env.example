# Kandidly environment (SPEC §6.1). Copy to infra/.env and fill secrets.
# All app-consumed vars are prefixed KANDIDLY_ in code via pydantic-settings.

# --- core ---
KANDIDLY_ENV=dev

# --- datastores (compose DNS names; override for managed prod) ---
KANDIDLY_DATABASE_URL=postgresql+asyncpg://kandidly:kandidly@postgres:5432/kandidly
KANDIDLY_REDIS_URL=redis://redis:6379/0

# --- object store (MinIO in dev) ---
KANDIDLY_S3_ENDPOINT=http://minio:9000
KANDIDLY_S3_ACCESS_KEY=kandidly
KANDIDLY_S3_SECRET_KEY=kandidly-secret
KANDIDLY_S3_REGION=us-east-1

# --- auth contract (SPEC §3.6) ---
KANDIDLY_JWT_PUBLIC_KEY=
KANDIDLY_JWT_ALG=RS256
KANDIDLY_AUTH_DEV_MODE=true

# --- internal service auth (agent/worker <-> backend, SPEC §12.4) ---
KANDIDLY_SERVICE_TOKEN=dev-service-token-change-me

# --- captcha (Google reCAPTCHA v3, guards candidate form submit) ---
# Leave the secret empty to skip verification in dev (fail-open); set both keys
# in prod. Site key is served to the browser via /api/public/config.
KANDIDLY_RECAPTCHA_SITE_KEY=
KANDIDLY_RECAPTCHA_SECRET_KEY=
KANDIDLY_RECAPTCHA_MIN_SCORE=0.5

# --- source scraping (interview context enrichment) ---
# Optional GitHub token to lift the REST rate limit (60→5000/hr). Empty is fine.
KANDIDLY_GITHUB_TOKEN=

# --- LiveKit ---
KANDIDLY_LIVEKIT_URL=
KANDIDLY_LIVEKIT_API_KEY=
KANDIDLY_LIVEKIT_API_SECRET=

# --- providers ---
KANDIDLY_DEEPGRAM_API_KEY=
KANDIDLY_CARTESIA_API_KEY=
KANDIDLY_ANTHROPIC_API_KEY=
KANDIDLY_OPENAI_API_KEY=
KANDIDLY_GOOGLE_API_KEY=
# OpenRouter (OpenAI-compatible) — serves the non-realtime LLM roles below.
KANDIDLY_OPENROUTER_API_KEY=

# --- model matrix (SPEC §3.3) ---
# Realtime role runs on the LiveKit agent's own inference gateway (leave as-is).
# The rest run through pydantic-ai via OpenRouter (`openrouter:<model>`).
KANDIDLY_REALTIME_LLM=anthropic:claude-haiku-4-5
KANDIDLY_EXTRACT_LLM=openrouter:qwen/qwen3-30b-a3b-instruct-2507
KANDIDLY_PLAN_LLM=openrouter:qwen/qwen3-30b-a3b-instruct-2507
KANDIDLY_ANNOTATE_LLM=openrouter:qwen/qwen3-30b-a3b-instruct-2507
KANDIDLY_SCORE_LLM=openrouter:qwen/qwen3-30b-a3b-instruct-2507
KANDIDLY_REPORT_LLM=openrouter:qwen/qwen3-30b-a3b-instruct-2507
# Vision model for proctoring snapshot analysis (must support image input;
# structured output is prompted-JSON, so tool support is not required).
KANDIDLY_VISION_LLM=openrouter:qwen/qwen2.5-vl-72b-instruct
# Text model that turns the per-frame analyses into the final integrity verdict.
KANDIDLY_INTEGRITY_LLM=openrouter:qwen/qwen3-30b-a3b-instruct-2507
KANDIDLY_STT=deepgram:nova-3
KANDIDLY_TTS=cartesia:sonic
KANDIDLY_TTS_VOICE=

# --- interview tuning ---
KANDIDLY_BASE_URL_WEB=http://localhost:5173
KANDIDLY_MAX_INTERVIEW_SECONDS=1800
KANDIDLY_WRAP_TRIGGER_SECONDS=180
KANDIDLY_REJOIN_GRACE_SECONDS=600
# Proctoring webcam capture cadence — one frame every N seconds.
KANDIDLY_SNAPSHOT_INTERVAL_S=10
# Ceiling on frames analyzed per interview (every frame is analyzed, in order,
# up to this budget — 180 = 30 min at the 10s cadence).
KANDIDLY_VISION_MAX_FRAMES=180
KANDIDLY_SCORING_RUNS=3
KANDIDLY_AGENT_MAX_CONCURRENT=50
KANDIDLY_RETENTION_DAYS_SNAPSHOTS=180
KANDIDLY_RETENTION_DAYS_AUDIO=365

# --- MinIO server creds (compose only, not app-facing) ---
MINIO_ROOT_USER=kandidly
MINIO_ROOT_PASSWORD=kandidly-secret

# --- Postgres server creds (compose only) ---
POSTGRES_USER=kandidly
POSTGRES_PASSWORD=kandidly
POSTGRES_DB=kandidly
